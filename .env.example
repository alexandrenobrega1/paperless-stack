# Copy this to .env and fill in your values
# NEVER commit .env to git - only commit .env.example

# ─────────────────────────────────────────
# User & Permissions
# ─────────────────────────────────────────
PUID=1003
PGID=986

# ─────────────────────────────────────────
# Timezone
# ─────────────────────────────────────────
TZ=Europe/Berlin

# ─────────────────────────────────────────
# Tailscale
# ─────────────────────────────────────────
TS_AUTHKEY=                  # your Tailscale auth key
TS_HOSTNAME=paperless        # hostname on Tailscale network
TS_DOMAIN=                   # your ts.net domain e.g. tail1234.ts.net

# ─────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────
PAPERLESS_DB_NAME=paperless
PAPERLESS_DB_USER=paperless
PAPERLESS_DB_PASS=            # choose a strong password

# ─────────────────────────────────────────
# Paperless-NGX
# ─────────────────────────────────────────
PAPERLESS_SECRET_KEY=         # generate with: openssl rand -hex 32
PAPERLESS_API_TOKEN=          # get from Paperless UI after first login

# ─────────────────────────────────────────
# Anthropic
# ─────────────────────────────────────────
ANTHROPIC_API_KEY=            # your Anthropic API key
